  "settingsSchema": {
    "title": "CleverTap",
    "type": "object",
    "properties": {
      "accountID": {
        "title": "CleverTap Project ID",
        "description": "Enter the Project ID of your CleverTap account.",
        "type": "string",
        "minLength": 1,
        "maxLength": 12
      },
      "accountPasscode": {
        "title": "CleverTap Account Passcode",
        "description": "Provide the authentication passcode for your CleverTap account.",
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "region": {
        "title": "CleverTap Region",
        "description": "Specify the CleverTap account region (e.g., us1, in1, sg1).",
        "type": "string",
        "minLength": 1,
        "maxLength": 4
      },
      "preferences": {
        "title": "Preference Settings",
        "type": "object",
        "properties": {
          "allowUnknownUsersEvents": {
            "title": "Allow Events from Unknown Users",
            "description": "Enable this option to track events even when the user is not identified.",
            "default": true,
            "type": "boolean"
          },
          "trackEvents": {
            "title": "Track Events",
            "description": "Enable or disable specific events to be tracked in your store.",
            "type": "object",
            "properties": {
              "vtex:search": {
                "title": "Products Searched",
                "type": "boolean",
                "default": true
              },
              "vtex:filterManipulation": {
                "title": "Product Filtered By Category",
                "type": "boolean",
                "default": true
              },
              "categoryView": {
                "title": "Product List Viewed",
                "type": "boolean",
                "default": true
              },
              "vtex:promoView": {
                "title": "Promotion Viewed",
                "type": "boolean",
                "default": true
              },
              "vtex:promotionClick": {
                "title": "Promotion Clicked",
                "type": "boolean",
                "default": true
              },
              "vtex:productView": {
                "title": "Product Viewed",
                "type": "boolean",
                "default": true
              },
              "vtex:productClick": {
                "title": "Product Clicked",
                "type": "boolean",
                "default": true
              },
              "vtex:addToCart": {
                "title": "Product Added To Cart",
                "type": "boolean",
                "default": true
              },
              "vtex:removeFromCart": {
                "title": "Product Removed From Cart",
                "type": "boolean",
                "default": true
              },
              "vtex:viewCart": {
                "title": "Cart Viewed",
                "type": "boolean",
                "default": true
              },
              "vtex:addToWishlist": {
                "title": "Product Added to Wishlist",
                "type": "boolean",
                "default": true
              },
              "vtex:removeToWishlist": {
                "title": "Product Removed from Wishlist",
                "type": "boolean",
                "default": true
              },
              "vtex:share": {
                "title": "Product Shared",
                "type": "boolean",
                "default": true
              },
              "vtex:orderPlaced": {
                "title": "Order Created",
                "type": "boolean",
                "default": true
              },
              "add_to_cart": {
                "title": "Checkout Product Added To Cart",
                "type": "boolean",
                "default": true
              },
              "remove_from_cart": {
                "title": "Checkout Product Removed From Cart",
                "type": "boolean",
                "default": true
              },
              "view_cart": {
                "title": "Checkout Cart Viewed",
                "type": "boolean",
                "default": true
              },
              "begin_checkout": {
                "title": "Checkout Started",
                "type": "boolean",
                "default": true
              },
              "add_payment_info": {
                "title": "Payment info",
                "type": "boolean",
                "default": true
              },
              "checkout_step_viewed": {
                "title": "Checkout Step Viewed/Completed",
                "type": "boolean",
                "default": true
              },
              "coupon_applied": {
                "title": "Coupon Applied",
                "type": "boolean",
                "default": true
              },
              "coupon_denied": {
                "title": "Coupon Denied",
                "type": "boolean",
                "default": true
              }
            }
          },
          "catalogSync": {
            "title": "Active Catalog Sync",
            "description": "Enable this option to automatically sync the catalog every 24 hours.",
            "default": true,
            "type": "boolean"
          },
          "useChargeEventOnlyWhenOrderApproved": {
            "title": "Use Charged event only when order is approved",
            "description": "When enabled, the Charged event is sent only after payment is approved. When disabled, the Charged event is sent when the customer places the order.",
            "default": true,
            "type": "boolean"
          },
          "integrationEmail": {
            "title": "Integration Email",
            "description": "Email address used for catalog integration",
            "minLength": 1,
            "type": "string",
            "format": "email"
          }
        }
      }
    }
  },
  "$schema": "https://raw.githubusercontent.com/vtex/node-vtex-api/master/gen/manifest.schema"
}
