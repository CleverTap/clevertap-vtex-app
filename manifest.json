{
  "name": "vtex-clevertap-app",
  "vendor": "clevertappartnerbr",
  "version": "0.0.12",
  "title": "VTEX CleverTap pixel app",
  "description": "VTEX app para integração com CleverTap, permitindo envio de eventos e campanhas.",
  "billingOptions": {
    "termsURL": "https://compliance.vtex.com/gdpr/policies/vtex-privacy-policy",
    "support": {
      "url": "https://support.vtex.com/hc/requests"
    },
    "free": true,
    "type": "free",
    "availableCountries": ["*"]
  },
  "builders": {
    "node": "6.x",
    "react": "3.x",
    "store": "0.x",
    "pixel": "0.x",
    "service-worker": "0.x",
    "docs": "0.x"
  },
  "dependencies": {
    "vtex.pixel-interfaces": "1.x"
  },
  "credentialType": "absolute",
  "policies": [
    {
      "name": "outbound-access",
      "attrs": {
        "host": "us1.api.clevertap.com",
        "path": "/*"
      }
    },
    {
      "name": "colossus-fire-event"
    },
    {
      "name": "colossus-write-logs"
    }
  ],
  "settingsSchema": {
    "title": "VTEX CleverTap pixel app",
    "type": "object",
    "properties": {
      "accountID": {
        "title": "Project ID",
        "description": "Enter a value",
        "type": "string"
      },
      "accountPasscode": {
        "title": "Account passcode",
        "description": "Enter a value",
        "type": "string"
      },
      "region": {
        "title": "Region",
        "description": "Enter a value",
        "type": "string"
      }
    }
  },
  "$schema": "https://raw.githubusercontent.com/vtex/node-vtex-api/master/gen/manifest.schema"
}
